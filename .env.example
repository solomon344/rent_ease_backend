# ===========================================
# RentEase Backend - Environment Configuration
# ===========================================
# Copy this file to .env and configure for your deployment environment
# cp .env.example .env

# -------------------------------------------
# Django Core Settings
# -------------------------------------------
# SECRET_KEY is required - generate a strong random key for production
# You can use: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to True only for development, must be False in production
DEBUG=False

# Comma-separated list of allowed host/domain names
# Format: host1,host2,host3 (no spaces)
ALLOWED_HOSTS=localhost,127.0.0.1

# -------------------------------------------
# Database Configuration
# -------------------------------------------
# Default is SQLite for development
# For PostgreSQL: DB_ENGINE=django.db.backends.postgresql
# For MySQL: DB_ENGINE=django.db.backends.mysql
DB_ENGINE=django.db.backends.sqlite3
DB_NAME=./db.sqlite3
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=

# Example PostgreSQL configuration:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=rentease_db
# DB_USER=rentease_user
# DB_PASSWORD=your_secure_password
# DB_HOST=localhost
# DB_PORT=5432

# -------------------------------------------
# Email Configuration (Gmail example)
# -------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@rentease.com

# -------------------------------------------
# Payment Configuration (Modem)
# -------------------------------------------
MODEM_API_KEY=your-modem-api-key
MODEM_WEBHOOK_SECRET=your-modem-webhook-secret
MODEM_PAYMENT_CURRENCY=GMD
MODEM_PAYMENT_METHODS=wave

# -------------------------------------------
# Google OAuth Configuration
# -------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# -------------------------------------------
# Frontend/Backend URLs
# -------------------------------------------
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000