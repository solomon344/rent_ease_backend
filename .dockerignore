# Git
.git
.gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environment (will be recreated in container)
.venv/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Environment variables (should never be in the image)
.env
.env.*
.env.example

# Logs
logs/
*.log

# Database (SQLite - don't include in image)
db.sqlite3
*.db

# Static files (will be collected during build)
staticfiles/
static/

# Media files (should be stored externally)
media/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Build artifacts
build/
dist/
*.egg-info/
*.egg

# Docker
Dockerfile
.dockerignore
docker-compose*.yml

# Documentation
*.md
!README.md